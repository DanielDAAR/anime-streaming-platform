---
export const prerender = false;

import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import AnimeCard from '../components/AnimeCard.astro';
import { apiUrl } from '../services/api';

const page = parseInt(Astro.url.searchParams.get('page') || '1');
const limit = 20;
const search = Astro.url.searchParams.get('search') || '';
const genre = Astro.url.searchParams.get('genre') || '';
const status = Astro.url.searchParams.get('status') || '';

let animes: any[] = [];
let total = 0;
let totalPages = 0;

try {
  const params = new URLSearchParams();
  params.set('page', String(page));
  params.set('limit', String(limit));
  if (search) params.set('search', search);
  if (genre) params.set('genre', genre);
  if (status) params.set('status', status);

  const res = await fetch(apiUrl(`/animes?${params}`));
  if (res.ok) {
    const data = await res.json();
    animes = data.data || [];
    total = data.meta?.total || 0;
    totalPages = data.meta?.totalPages || 0;
  }
} catch (e) {
  console.error('Error fetching catalog:', e);
}

const genres = ['Acción', 'Aventura', 'Comedia', 'Drama', 'Fantasía', 'Romance', 'Terror', 'Sci-Fi', 'Deportes'];
const statuses = [
  { value: 'ongoing', label: 'En Emisión' },
  { value: 'completed', label: 'Finalizado' },
  { value: 'upcoming', label: 'Próximamente' },
];
---

<MainLayout 
  title="Catálogo de Animes"
  description="Explora nuestro catálogo completo de animes. Filtra por género, estado y más."
  canonical={`/catalogo?page=${page}`}
>
  <Navbar />

  <section class="section">
    <div class="container">
      <h1 class="title is-2">Catálogo</h1>

      <!-- Filters -->
      <div class="box mb-5" style="background: #1a1a2e; border: 1px solid #2d2d44;">
        <form method="GET" action="/catalogo">
          <div class="columns">
            <div class="column is-4">
              <div class="field">
                <label class="label">Buscar</label>
                <div class="control search-box">
                  <input 
                    type="text" 
                    name="search" 
                    class="input" 
                    placeholder="Nombre del anime..."
                    value={search}
                  />
                </div>
              </div>
            </div>
            <div class="column is-3">
              <div class="field">
                <label class="label">Género</label>
                <div class="control">
                  <div class="select is-fullwidth">
                    <select name="genre">
                      <option value="">Todos</option>
                      {genres.map(g => (
                        <option value={g} selected={genre === g}>{g}</option>
                      ))}
                    </select>
                  </div>
                </div>
              </div>
            </div>
            <div class="column is-3">
              <div class="field">
                <label class="label">Estado</label>
                <div class="control">
                  <div class="select is-fullwidth">
                    <select name="status">
                      <option value="">Todos</option>
                      {statuses.map(s => (
                        <option value={s.value} selected={status === s.value}>{s.label}</option>
                      ))}
                    </select>
                  </div>
                </div>
              </div>
            </div>
            <div class="column is-2">
              <div class="field">
                <label class="label">&nbsp;</label>
                <button type="submit" class="button is-primary is-fullwidth">
                  Filtrar
                </button>
              </div>
            </div>
          </div>
        </form>
      </div>

      <!-- Results -->
      {animes.length > 0 ? (
        <>
          <p class="has-text-grey mb-4">Mostrando {animes.length} de {total} resultados</p>
          <div class="columns is-multiline">
            {animes.map(anime => (
              <div class="column is-3-desktop is-4-tablet is-6-mobile">
                <AnimeCard anime={anime} />
              </div>
            ))}
          </div>

          <!-- Pagination -->
          {totalPages > 1 && (
            <nav class="pagination is-centered mt-6" role="navigation">
              <a 
                class={`pagination-previous ${page <= 1 ? 'is-disabled' : ''}`}
                href={page > 1 ? `/catalogo?page=${page - 1}&search=${search}&genre=${genre}&status=${status}` : '#'}
              >
                ← Anterior
              </a>
              <a 
                class={`pagination-next ${page >= totalPages ? 'is-disabled' : ''}`}
                href={page < totalPages ? `/catalogo?page=${page + 1}&search=${search}&genre=${genre}&status=${status}` : '#'}
              >
                Siguiente →
              </a>
              <ul class="pagination-list">
                {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
                  <li>
                    <a 
                      class={`pagination-link ${p === page ? 'is-current' : ''}`}
                      href={`/catalogo?page=${p}&search=${search}&genre=${genre}&status=${status}`}
                    >
                      {p}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          )}
        </>
      ) : (
        <div class="has-text-centered py-6">
          <p class="is-size-4 has-text-grey">No se encontraron animes</p>
          <a href="/catalogo" class="button is-primary mt-4">Ver todos</a>
        </div>
      )}
    </div>
  </section>

  <Footer />
</MainLayout>
