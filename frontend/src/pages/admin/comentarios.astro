---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { apiUrl } from '../../services/api';

let comments: any[] = [];
let total = 0;

const page = parseInt(Astro.url.searchParams.get('page') || '1');
const token = Astro.cookies.get('token')?.value;

try {
  const res = await fetch(apiUrl(`/comments?page=${page}&limit=20`), {
    headers: token ? { 'Authorization': `Bearer ${token}` } : {}
  });
  if (res.ok) {
    const data = await res.json();
    comments = data.data || [];
    total = data.meta?.total || 0;
  }
} catch (e) {
  console.error('Error fetching comments:', e);
}
---

<AdminLayout title="Moderación de Comentarios">
  <div class="level">
    <div class="level-left">
      <h2 class="title is-4">💬 Moderación de Comentarios</h2>
    </div>
    <div class="level-right">
      <span class="tag is-info">{total} comentarios totales</span>
    </div>
  </div>

  <div class="box" style="background: #1a1a2e; border: 1px solid #2d2d44;">
    {comments.length > 0 ? (
      <div class="comments-list">
        {comments.map(comment => (
          <div class="comment-item mb-4" data-comment-id={comment.id}>
            <div class="is-flex is-justify-content-space-between is-align-items-start">
              <div>
                <div class="comment-header">
                  <span class="has-text-weight-bold has-text-primary">{comment.user?.username || 'Unknown'}</span>
                  <span class="has-text-grey is-size-7 ml-2">
                    {new Date(comment.createdAt).toLocaleString('es-ES')}
                  </span>
                  {comment.isDeleted && <span class="tag is-danger is-small ml-2">Eliminado</span>}
                </div>
                <p class="mt-2">{comment.content}</p>
                <div class="tags mt-2">
                  <span class="tag is-small">👍 {comment.likes}</span>
                  <span class="tag is-small">🎬 {comment.animeId}</span>
                </div>
              </div>
              <div class="buttons are-small">
                {!comment.isDeleted && (
                  <button class="button is-danger delete-comment-btn" data-id={comment.id}>
                    🗑️ Eliminar
                  </button>
                )}
              </div>
            </div>
            <hr style="background: #2d2d44; margin: 1rem 0;" />
          </div>
        ))}
      </div>
    ) : (
      <div class="has-text-centered py-5">
        <p class="has-text-grey">No hay comentarios para moderar.</p>
      </div>
    )}
  </div>

  <script>
    import { commentApi } from '../../services/api';

    document.querySelectorAll('.delete-comment-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('¿Eliminar este comentario?')) return;

        const id = btn.getAttribute('data-id');
        try {
          await commentApi.delete(id!);
          window.location.reload();
        } catch (err) {
          alert('Error al eliminar comentario');
        }
      });
    });
  </script>
</AdminLayout>
